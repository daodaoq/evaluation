<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.project.evaluation.mapper.TimeMapper">
    <select id="paginationQuery" resultType="com.project.evaluation.entity.Time">
        SELECT * FROM `evaluation_period`
        <where>
            <if test="periodName != null and periodName != ''">
                period_name = #{periodName}
            </if>
            <if test="statuses != null and statuses.size() &gt; 0">
                AND status IN
                <foreach collection="statuses" item="st" open="(" separator="," close=")">#{st}</foreach>
            </if>
        </where>
    </select>
</mapper>