<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.project.evaluation.mapper.ClassMapper">

    <select id="paginationQuery" resultType="com.project.evaluation.entity.Class">
        SELECT * FROM `sys_class`
        <where>
            <if test="collegeId != null">
                AND college_id = #{collegeId}
            </if>
            <if test="gradeYear != null">
                AND grade_year = #{gradeYear}
            </if>
        </where>
        ORDER BY create_time DESC
    </select>
</mapper>