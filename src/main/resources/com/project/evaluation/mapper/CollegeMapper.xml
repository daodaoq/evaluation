<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.project.evaluation.mapper.CollegeMapper">

    <select id="paginationQuery" resultType="com.project.evaluation.entity.College">
        SELECT * FROM `sys_college`
        <where>
            <if test="statuses != null and statuses.size() &gt; 0">
                AND status IN
                <foreach collection="statuses" item="st" open="(" separator="," close=")">#{st}</foreach>
            </if>
        </where>
        ORDER BY create_time DESC
    </select>
</mapper>
